# GitHub Ayarları
GITHUB_USERNAME=your_username
GITHUB_TOKEN=your_personal_access_token

# Görünürlük Ayarları (Gizlilik İçin)
# true (göster) / false (gizle)
SHOW_SYSTEM_LOGS=true
SHOW_ACTIVE_PROJECTS=true

# API Önbellek (Cache) Süresi (Dakika cinsinden)
# Çok düşük yaparsanız GitHub API Rate Limit (istek sınırı) hatası alabilirsiniz. Varsayılan: 10
CACHE_DURATION_MINUTES=10

# Arayüz Teması (Ana Yapı)
# Seçenekler: jarvis, activity_monitor, nitro_hud, hacker_terminal, minimal_light, glass_light
UI_THEME=glass_light

# Varsayılan Renk (jarvis teması için geçerlidir)
# Seçenekler: theme-cyan, theme-orange, theme-red, theme-green, theme-purple
DEFAULT_THEME=theme-cyan
