# GitHub Ayarları
GITHUB_USERNAME=your_username
GITHUB_TOKEN=your_personal_access_token

# Görünürlük Ayarları (Gizlilik İçin)
# true (göster) / false (gizle)
SHOW_SYSTEM_LOGS=true
SHOW_ACTIVE_PROJECTS=true

# Varsayılan Tema (theme-cyan, theme-orange, theme-red, theme-green, theme-purple)
DEFAULT_THEME=theme-cyan
